server {
    listen 80;
    server_name api.fusional.dev;

    # Pass the upstream's own host:port so MCP host-validation passes
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Required for MCP streaming (SSE / StreamableHTTP)
    proxy_buffering off;
    proxy_cache off;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    chunked_transfer_encoding on;

    # FusionAL (main service)
    location /fusional/ {
        proxy_pass http://localhost:8009/;
    }

    location /health {
        proxy_pass http://localhost:8009/health;
    }

    # Other services
    location /bi/ {
        proxy_pass http://localhost:8101/;
    }

    location /api/ {
        proxy_pass http://localhost:8102/;
    }

    location /content/ {
        proxy_pass http://localhost:8103/;
    }

    location /intel/ {
        proxy_pass http://localhost:8104/;
    }

    # Default to FusionAL
    location / {
        proxy_pass http://localhost:8009/;
    }
}
