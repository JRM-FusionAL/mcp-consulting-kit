# Generate a real file named .htpasswd (without .example) before starting proxy.
# IMPORTANT: filename must start with a dot: .htpasswd
# Example commands on Ubuntu (run from repo root):
#   sudo apt-get update ; sudo apt-get install -y apache2-utils
#   sudo mkdir -p deploy/nginx
#   sudo htpasswd -cb deploy/nginx/.htpasswd mcpadmin CHANGE_ME_STRONG_PASSWORD
# If you see "cannot create file", verify path and working directory:
#   pwd
#   ls -la deploy/nginx
#   # common typo: deploy/nginx/htpasswd (missing leading dot)
#   # must use sudo for elevated privileges when creating .htpasswd
# This example file is not used by nginx.
